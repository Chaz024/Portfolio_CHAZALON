---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';

interface Credit { name: string; license: string; author: string; source: string }
const raw = fs.readFileSync(path.join(process.cwd(), 'public', 'covers', 'credits.json'), 'utf-8');
const items: Credit[] = JSON.parse(raw);
---
<Base
  title="Crédits — Hugo Chazalon"
  description="Crédits et licences des visuels utilisés dans les animations du portfolio."
>
  <section class="wrap cr-head">
    <p class="mono-label kicker"><span class="accent">Crédits</span> — visuels &amp; licences</p>
    <h1 class="display cr-h">D'où viennent les images</h1>
    <p class="serif cr-lead">Les visuels de l'animation de transition vers l'index sont soit générés
      pour ce site, soit issus de <strong>Wikimedia Commons</strong> sous licence libre. Attribution
      ci-dessous, conformément aux licences.</p>
  </section>

  <section class="wrap">
    <ul class="cr-list rule-top" role="list">
      {items.map((c) => (
        <li class="cr-row">
          <span class="cr-name display">{c.name}</span>
          <span class="cr-meta mono-label">{c.license} · {c.author}</span>
          {c.source
            ? <a class="cr-src mono-label" href={c.source} rel="noopener" target="_blank">Source ↗</a>
            : <span class="cr-src mono-label muted">—</span>}
        </li>
      ))}
    </ul>
  </section>
</Base>
<style>
  .cr-head{padding-block:70px 30px;}
  .kicker{margin-bottom:26px;}
  .cr-h{font-size:var(--t-xl);margin-bottom:22px;}
  .cr-lead{max-width:54ch;color:#55534b;font-size:1.05rem;}
  .cr-list{list-style:none;}
  .cr-row{border-bottom:1px solid var(--rule);padding:18px 0;display:grid;
    grid-template-columns:1.4fr 2fr auto;gap:18px;align-items:baseline;}
  .cr-name{font-size:1.05rem;}
  .cr-meta{color:#8a887f;text-transform:none;letter-spacing:.04em;}
  .cr-src{color:var(--accent);text-decoration:none;white-space:nowrap;}
  .cr-src:hover{text-decoration:underline;}
  .muted{color:#8a887f;}
  @media (max-width:700px){ .cr-row{grid-template-columns:1fr;gap:6px;} }
</style>
