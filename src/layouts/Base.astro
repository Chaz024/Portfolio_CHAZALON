---
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import FooterCartouche from '../components/FooterCartouche.astro';
import { withBase } from '../lib/url';
interface Props { title: string; description: string; ogImage?: string }
const { title, description, ogImage } = Astro.props;
const og = new URL(ogImage ?? withBase('/og.jpg'), Astro.site);
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={og} />
  <meta property="og:type" content="website" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <ClientRouter />
</head>
<body>
  <a class="skip-link" href="#main">Aller au contenu</a>
  <Nav />
  <main id="main"><slot /></main>
  <FooterCartouche />
  <div class="curtain" aria-hidden="true"></div>
  <script>
    import { initMotion, initCurtain } from '../lib/reveal';
    initCurtain();
    document.addEventListener('astro:page-load', initMotion);
  </script>
</body>
</html>
<style is:global>
  .curtain{position:fixed;inset:0;background:var(--accent);transform:translateY(101%);z-index:90;pointer-events:none;}
</style>
