---
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';
const etudes = (await getCollection('etudes')).sort((a, b) => a.data.num - b.data.num);
---
<ol class="index rule-top" role="list">
  {etudes.map((e) => (
    <li class="row">
      <a href={withBase(`/etudes/${e.id.replace(/\.mdx$/, '')}`)} class="grid-row">
        <span class="num display" aria-hidden="true">{String(e.data.num).padStart(2, '0')}</span>
        <span class="body">
          <span class="title display">{e.data.title}</span>
          <span class="meta mono-label">{e.data.methods.join(' · ')} — {e.data.tools.join(', ')}</span>
        </span>
        <span class="metric mono-label">{e.data.metric}</span>
        <span class="cycle mono-label">{e.data.periode}</span>
      </a>
    </li>
  ))}
</ol>
<style>
  .index{list-style:none;}
  .row{border-bottom:1px solid var(--rule);}
  .grid-row{display:grid;grid-template-columns:72px 1.5fr 1fr 150px;gap:18px;align-items:baseline;
    padding:20px 0;text-decoration:none;}
  .num{font-size:1.5rem;color:var(--accent);}
  .title{font-size:1.05rem;display:block;}
  .meta{display:block;margin-top:6px;color:#8a887f;letter-spacing:.08em;text-transform:none;}
  .metric{color:#55534b;letter-spacing:.06em;text-transform:none;}
  .cycle{text-align:right;color:#8a887f;}
  .grid-row:hover .title{color:var(--accent);}
  .grid-row:hover .num{transform:translateX(6px);transition:transform .2s;}
  @media (max-width:820px){ .grid-row{grid-template-columns:52px 1fr;} .metric,.cycle{grid-column:2;} }
</style>
