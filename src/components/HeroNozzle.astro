<figure class="plate nozzle" aria-label="Figure interactive : écoulement dans une tuyère De Laval">
  <div class="frame"><canvas id="nozzle" width="800" height="300"></canvas></div>
  <figcaption class="mono-label">
    <span class="accent">PL. 00 (INTERACTIVE)</span> — Tuyère De Laval, relation aire–Mach. Couleur = Mach local.
    <span class="ctrl">
      <label for="mach">M<sub>e</sub></label>
      <input id="mach" type="range" min="1.2" max="3.2" step="0.05" value="2.2" />
      <output for="mach" id="machOut">2.20</output>
    </span>
  </figcaption>
</figure>
<script>
  import { NozzleSim } from '../lib/nozzle-render';
  const canvas = document.getElementById('nozzle') as HTMLCanvasElement | null;
  const slider = document.getElementById('mach') as HTMLInputElement | null;
  const out = document.getElementById('machOut');
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (canvas && slider && out) {
    const sim = new NozzleSim(canvas);
    const draw = () => { sim.Me = parseFloat(slider.value); out.textContent = sim.Me.toFixed(2); if (reduced) sim.renderFrame(); };
    slider.addEventListener('input', draw); draw();
    if (!reduced) sim.start(); else sim.renderFrame();
    const onResize = () => { sim.resize(); if (reduced) sim.renderFrame(); };
    addEventListener('resize', onResize);
    document.addEventListener('astro:before-swap', () => { sim.stop(); removeEventListener('resize', onResize); }, { once: true });
  }
</script>
<style>
  .frame{border:1px solid var(--ink);padding:10px;background:#fff;}
  canvas{width:100%;height:300px;display:block;}
  figcaption{margin-top:10px;color:#55534b;display:flex;flex-wrap:wrap;gap:8px 18px;align-items:center;}
  .ctrl{display:inline-flex;align-items:center;gap:10px;}
  input[type=range]{accent-color:var(--accent);width:150px;}
  output{color:var(--accent);min-width:4ch;}
</style>
