---
import { withBase } from '../lib/url';
import { contact } from '../data/contact';
const { pathname } = Astro.url;
const links = [
  { href: withBase('/#etudes'), label: 'Index' },
  { href: withBase('/profil'), label: 'Profil' },
  { href: withBase('/#contact'), label: 'Contact' },
];
---
<header class="nav rule-bottom">
  <div class="wrap bar">
    <a class="name display" href={withBase('/')}>Chazalon</a>
    <nav aria-label="Navigation principale">
      <ul class="mono-label">
        {links.map((l) => (
          <li><a href={l.href} aria-current={pathname === l.href ? 'page' : undefined}>{l.label}</a></li>
        ))}
        {contact.cvPath && <li><a class="cv" href={withBase(contact.cvPath)} download>CV ↓</a></li>}
      </ul>
    </nav>
  </div>
</header>
<style>
  .nav{position:sticky;top:0;background:var(--paper);z-index:50;}
  .bar{display:flex;justify-content:space-between;align-items:center;padding-block:14px;}
  .name{font-size:1.05rem;text-decoration:none;}
  ul{display:flex;gap:28px;list-style:none;}
  a{text-decoration:none;}
  a[aria-current="page"], a:hover{color:var(--accent);}
  .cv{background:var(--accent);color:#fff;padding:6px 12px;}
  .cv:hover{color:#fff;background:var(--ink);}
  @media (max-width:600px){ ul{gap:16px;} .bar{flex-wrap:wrap;gap:8px;} }
</style>
