---
import { getCollection } from 'astro:content';
import { planeParts, wholeAircraft } from '../../data/planeHotspots';
import { withBase } from '../../lib/url';
import PlaneViewer from './PlaneViewer';

const etudes = await getCollection('etudes');
const bySlug = new Map(etudes.map((e) => [e.id.replace(/\.mdx$/, ''), e]));

function toStudyRef(slug: string) {
  const e = bySlug.get(slug);
  if (!e) throw new Error(`planeHotspots : étude introuvable pour le slug « ${slug} »`);
  return {
    num: e.data.num,
    title: e.data.title,
    meta: `${e.data.methods.join(' · ')} — ${e.data.tools.join(', ')}`,
    url: withBase(`/etudes/${slug}`),
  };
}

const parts = planeParts.map((p) => ({
  id: p.id,
  label: p.label,
  anchor: p.anchor,
  camera: p.camera,
  studies: p.slugs.map(toStudyRef),
}));
const whole = { label: wholeAircraft.label, studies: wholeAircraft.slugs.map(toStudyRef) };
const total = parts.reduce((n, p) => n + p.studies.length, 0) + whole.studies.length;
const totalWord = ['zéro','une','deux','trois','quatre','cinq','six','sept','huit','neuf','dix'][total] ?? String(total);
---
<div class="plane-sec" id="avion" aria-label={`Planche interactive : un avion, ${totalWord} études ancrées aux pièces`}>
  <p class="mono-label plane-kicker"><span class="accent">PL. 00 (interactive)</span> — Un avion, {totalWord} études ancrées aux pièces qu'elles concernent</p>
  <PlaneViewer client:only="react" parts={parts} whole={whole} modelUrl={withBase('/models/a380.glb')} />
  <noscript>
    <ul class="plane-noscript" role="list">
      {parts.flatMap((p) =>
        p.studies.map((s) => (
          <li class="mono-label">
            <a href={s.url}><span class="accent">{String(s.num).padStart(2, '0')}</span> {p.label} — {s.title}</a>
          </li>
        ))
      )}
      {whole.studies.map((s) => (
        <li class="mono-label">
          <a href={s.url}><span class="accent">{String(s.num).padStart(2, '0')}</span> {whole.label} — {s.title}</a>
        </li>
      ))}
    </ul>
  </noscript>
</div>

<style is:global>
  .plane-sec .plane-kicker{margin-bottom:16px;color:#55534b;}
  .plane-noscript{list-style:none;border-top:1px solid var(--ink);}
  .plane-noscript li{border-bottom:1px solid var(--rule);padding:12px 0;}
  .plane-noscript a{text-decoration:none;}

  /* ---- grille îlot ---- */
  .pv-grid{display:grid;grid-template-columns:minmax(0,7.2fr) minmax(0,4.8fr);gap:0 24px;align-items:stretch;}
  .pv-stage{position:relative;margin:0;border:1px solid var(--rule);min-height:480px;}
  .pv-stage canvas{touch-action:pan-y;}
  .pv-tick{position:absolute;width:14px;height:14px;pointer-events:none;}
  .pv-tick-tl{top:-1px;left:-1px;border-top:2px solid var(--ink);border-left:2px solid var(--ink);}
  .pv-tick-br{bottom:-1px;right:-1px;border-bottom:2px solid var(--ink);border-right:2px solid var(--ink);}
  .pv-caption{position:absolute;left:14px;bottom:10px;color:#8a887f;pointer-events:none;}
  .pv-loading{font-family:var(--font-mono);font-size:var(--t-xs);letter-spacing:.14em;
    text-transform:uppercase;color:#8a887f;white-space:nowrap;}

  /* ---- hotspots (portails drei Html) ---- */
  .pv-hs-wrap{z-index:5!important;}
  .pv-hs{display:grid;justify-items:start;gap:2px;background:none;border:none;cursor:pointer;
    font-family:var(--font-mono);padding:0;}
  .pv-hs-square{width:11px;height:11px;border:1.5px solid var(--ink);background:var(--paper);
    transition:background .18s,border-color .18s;}
  .pv-hs:hover .pv-hs-square,.pv-hs.is-active .pv-hs-square{background:var(--accent);border-color:var(--accent);}
  .pv-hs-id{font-size:var(--t-xs);letter-spacing:.12em;color:var(--ink);
    border-bottom:1px solid var(--ink);padding-bottom:1px;white-space:nowrap;}
  .pv-hs-label{font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:#8a887f;
    opacity:0;transform:translateY(-2px);transition:opacity .18s,transform .18s;white-space:nowrap;}
  .pv-hs:hover .pv-hs-label,.pv-hs.is-active .pv-hs-label{opacity:1;transform:none;}
  .pv-hs.is-active .pv-hs-id{color:var(--accent);border-color:var(--accent);}

  /* ---- fiche latérale ---- */
  .pv-card{border:1px solid var(--ink);position:relative;display:grid;min-height:480px;}
  .pv-card-in{padding:26px 26px 30px;display:grid;gap:18px;align-content:start;height:100%;}
  .pv-card-kicker{border-bottom:1px solid var(--ink);padding-bottom:12px;}
  .pv-study{display:grid;gap:8px;justify-items:start;padding-bottom:18px;border-bottom:1px solid var(--rule);}
  .pv-study:last-of-type{border-bottom:none;}
  .pv-study-num{font-size:1.5rem;color:var(--accent);}
  .pv-study-title{font-size:1.02rem;line-height:1.15;}
  .pv-study-meta{color:#8a887f;text-transform:none;letter-spacing:.08em;}
  .pv-study-link{color:var(--ink);text-decoration:none;border-bottom:1px solid var(--ink);padding-bottom:2px;}
  .pv-study-link:hover{color:var(--accent);border-color:var(--accent);}
  .pv-card-hint{font-size:.95rem;color:#55534b;max-width:34ch;}
  .pv-legend{list-style:none;display:grid;}
  .pv-legend li{border-bottom:1px solid var(--rule);}
  .pv-legend-row{display:flex;gap:14px;width:100%;background:none;border:none;cursor:pointer;
    padding:11px 2px;text-align:left;font-family:var(--font-mono);font-size:var(--t-xs);
    letter-spacing:.14em;text-transform:uppercase;color:var(--ink);}
  .pv-legend-row:hover{color:var(--accent);}
  .pv-whole{display:grid;gap:6px;text-decoration:none;border:1px solid var(--rule);padding:16px 18px;margin-top:auto;}
  .pv-whole:hover{border-color:var(--accent);}
  .pv-whole-title{font-size:.95rem;}

  /* ---- ink reveal ---- */
  .ink{filter:url(#ink-displace);height:100%;}
  .ink.ink-done{filter:none;}
  .ink-plain{height:100%;}
  .ink-clip{position:relative;height:100%;animation:ink-grow .85s cubic-bezier(.3,0,.2,1) both;}
  .ink-wash{position:absolute;inset:0;background:var(--accent);pointer-events:none;
    animation:ink-wash-out .5s .3s both;}
  @keyframes ink-grow{
    from{clip-path:circle(0% at 22% 14%);}
    to{clip-path:circle(145% at 22% 14%);}
  }
  @keyframes ink-wash-out{from{opacity:1;}to{opacity:0;}}

  @media (max-width:900px){
    .pv-grid{grid-template-columns:1fr;gap:18px;}
    .pv-stage{min-height:min(72vw,440px);}
    .pv-card{min-height:0;}
  }
</style>
